# Server
APP_ENV=development
SERVER_PORT=8080
UPLOAD_DIR=uploads

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=topmentor
DB_PASSWORD=topmentor_dev
DB_NAME=topmentor
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168

# 短信（开发默认 mock，验证码固定 123456）
SMS_MOCK_MODE=true
SMS_MOCK_CODE=123456

# CORS（H5 本地开发）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 支付（M3）
# mock = 立即到账，无需商户号；live = 走真实通道（需配置下方密钥）
PAYMENT_MODE=mock
SITE_URL=http://localhost:5173

# 微信（可选，H5 主登录为短信）
WX_APP_ID=
WX_APP_SECRET=
WX_MOCK_MODE=true
WX_MCH_ID=
WX_MCH_API_KEY=
WX_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/wechat

# 支付宝（live 模式选填）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/alipay

# 声网 Agora（M4 课室；未配置则 mock 模式）
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_MOCK_MODE=true
LESSON_DURATION_MINUTES=45

# 学霸端（M5）
LESSON_EARN_YUAN=80
WITHDRAW_MOCK_MODE=true

# 运营后台
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 阿里云 OSS
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# 生产环境：见 deploy/env.production.example 与 deploy/README.md

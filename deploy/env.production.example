# 复制到项目根目录并重命名为 .env
# cp deploy/env.production.example .env

# 域名（与 deploy/Caddyfile 联动，修改此处即可）
DOMAIN=toppeertalk.com
ADMIN_DOMAIN=admin.toppeertalk.com
ACME_EMAIL=admin@toppeertalk.com

APP_ENV=production
SERVER_PORT=8080
UPLOAD_DIR=/data/uploads

# PostgreSQL（docker-compose.prod.yml 内网服务名 postgres）
DB_HOST=postgres
DB_PORT=5432
DB_USER=topmentor
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=topmentor
DB_SSLMODE=disable

# Redis（内网服务名 redis）
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT（务必改为随机长字符串）
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
JWT_EXPIRE_HOURS=168

# 短信：生产环境关闭 mock，接入真实短信通道后再改
SMS_MOCK_MODE=true
SMS_MOCK_CODE=123456

# 站点 URL（H5 主站，用于支付回调跳转等）
SITE_URL=https://toppeertalk.com

# CORS（同域反代时可留空；若单独域名访问 API 再填写）
CORS_ORIGINS=https://toppeertalk.com,https://www.toppeertalk.com,https://admin.toppeertalk.com

# 支付
PAYMENT_MODE=mock
WX_NOTIFY_URL=https://toppeertalk.com/api/v1/payment/notify/wechat
ALIPAY_NOTIFY_URL=https://toppeertalk.com/api/v1/payment/notify/alipay

# 微信（可选）
WX_APP_ID=
WX_APP_SECRET=
WX_MOCK_MODE=true
WX_MCH_ID=
WX_MCH_API_KEY=

# 支付宝（live 模式选填）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 声网 Agora（课室；与本地 .env 保持一致时可填真实密钥）
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_MOCK_MODE=true
LESSON_DURATION_MINUTES=45

# 学霸端
LESSON_EARN_YUAN=80
WITHDRAW_MOCK_MODE=true

# 运营后台（务必修改默认密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# 阿里云 OSS（可选，未配置则本地上传）
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

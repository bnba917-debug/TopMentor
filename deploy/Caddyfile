{
	email {$ACME_EMAIL}
}

{$DOMAIN}, www.{$DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}

	handle /uploads/* {
		reverse_proxy api:8080
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

{$ADMIN_DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}

	handle {
		root * /srv/admin
		try_files {path} /index.html
		file_server
	}
}
